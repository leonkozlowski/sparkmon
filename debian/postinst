#!/bin/bash
# Post-installation script for sparkmon
set -e

echo "sparkmon installed."
echo ""
echo "Quick start:"
echo "  1. Deploy the exporters to your nodes:   sparkmon deploy me@spark-01 me@spark-02"
echo "  2. Check they're reachable:              sparkmon health spark-01 spark-02"
echo "  3. Run the dashboard:                    sparkmon -nodes spark-01=<ip>,spark-02=<ip>"
echo ""
echo "Sample config: /etc/sparkmon/config.yaml.example"
echo "  (copy to ~/.config/sparkmon/config.yaml and edit, then plain 'sparkmon' works)"
